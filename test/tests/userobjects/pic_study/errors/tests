[Tests]
  design = 'PICStudyBase.md'
  issues = '#144'
  [errors]
    requirement = "The system shall return a useful error when the user attempts to provide two initializers for the same species that provide inconsistent"
    [conflicting_masses]
      type = 'RunException'
      input = 'errors.i'
      cli_args = 'UserObjects/initializer_2/mass=2'
      allow_test_objects = true
      expect_err = 'provided different masses for species A'
      detail = 'masses'
    []
    [conflicting_charges]
      type = 'RunException'
      input = 'errors.i'
      cli_args = 'UserObjects/initializer_2/charge=2'
      allow_test_objects = true
      expect_err = 'provided different charges for species A'
      detail = 'charge'
    []
  []
[]
